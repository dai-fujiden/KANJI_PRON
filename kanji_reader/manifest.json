{
  "manifest_version": 3,
  "options_page": "options.html",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "name": "Kanji Reader",
  "version": "1.0",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "popup.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "kanji_data.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}